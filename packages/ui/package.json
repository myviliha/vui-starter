{
  "name": "@viliha/vui-ui",
  "version": "1.4.1",
  "description": "Vui UI — a clean, token-driven React admin/CRM component library built on Tailwind CSS v4, shadcn-style patterns, and Radix Icons. Ships as TypeScript source (Just-in-Time), compiled by the consuming app.",
  "license": "MIT",
  "author": "Suman Bonakurthi",
  "homepage": "https://vui.viliha.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myviliha/vui-starter.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/myviliha/vui-starter/issues"
  },
  "keywords": [
    "react",
    "tailwind",
    "tailwindcss",
    "shadcn",
    "radix",
    "admin",
    "dashboard",
    "crm",
    "ui",
    "components",
    "design-system"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "bin",
    "template",
    "AGENT.md",
    "CLAUDE.template.md"
  ],
  "bin": {
    "vui-ui": "bin/vui.mjs",
    "vui": "bin/vui.mjs"
  },
  "exports": {
    "./theme.css": "./src/theme.css",
    "./utils": "./src/utils.ts",
    "./*": "./src/*.tsx"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsgo --noEmit",
    "test": "vitest run",
    "sync-template": "node scripts/sync-template.mjs",
    "prepublishOnly": "node scripts/sync-template.mjs"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "clsx": "^2.1.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.10"
  }
}
